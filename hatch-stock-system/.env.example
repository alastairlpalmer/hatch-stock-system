# ============================================
# Hatch Stock Management - Frontend Configuration
# ============================================
# Copy this file to .env for local development
# For production, set these as environment variables in Vercel/Railway

# API Configuration
# Development: http://localhost:8000/api
# Production: https://your-backend.railway.app/api
VITE_API_URL=http://localhost:8000/api

# Authentication
# Set to true to gate the app behind the login screen. Must match the backend's
# AUTH_ENABLED. When true, unauthenticated visitors are redirected to /login and
# the session persists for 7 days (JWT in localStorage).
VITE_AUTH_ENABLED=false

# Feature Flags
VITE_ENABLE_SALES_IMPORT=true
VITE_ENABLE_AI_INVOICE=true
VITE_ENABLE_AI_SCREENSHOT=true

# Debug (disable in production)
VITE_DEBUG_MODE=true
