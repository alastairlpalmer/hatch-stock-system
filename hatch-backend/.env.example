# ============================================
# Hatch Stock Management - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=8000
NODE_ENV=development

# Frontend URL (for CORS) - can be comma-separated for multiple origins
# Development: http://localhost:3000,http://localhost:5173
# Production: https://your-app.vercel.app,https://yourdomain.com
FRONTEND_URL=http://localhost:3001

# ============================================
# DATABASE CONNECTION - Supabase
# ============================================
# IMPORTANT: Use the Transaction Pooler (port 6543) for DATABASE_URL — NOT the
# session pooler (port 5432) and NOT the direct connection. The session pooler
# holds one server connection per client for the whole session and is capped at
# ~15 clients; Prisma's default pool is (CPU cores * 2) + 1, which on a
# multi-core host exhausts that cap on its own and every query then fails with
# "FATAL: (EMAXCONNSESSION) max clients reached in session mode" (this took down
# sales ingestion in June 2026). The transaction pooler returns each connection
# after every transaction, so it does not hit that wall.
#
# Two flags are required/recommended on the URL:
#   - pgbouncer=true       REQUIRED in transaction mode (disables prepared
#                          statements, which pgbouncer can't share across clients)
#   - connection_limit=10  bounds Prisma's client-side pool. If you run multiple
#                          backend replicas, keep the COMBINED limit under the
#                          pooler's capacity.
#
# Get both URLs from: Supabase Dashboard > Settings > Database > Connection String
#   - "Transaction pooler" mode (port 6543) → DATABASE_URL (application queries).
#     Copy the host exactly as shown (the region prefix, e.g. aws-1-eu-west-1,
#     varies by project — a wrong prefix returns "tenant/user not found").
#   - "Direct connection"                   → DIRECT_DATABASE_URL (prisma migrations)
#
# Note: Special characters in password must be URL-encoded (e.g., ! = %21)

# Transaction Pooler — used by the app (all queries go through here)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# Direct connection — used by prisma migrate / db push only
DIRECT_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# ============================================
# AUTHENTICATION
# ============================================
# Set AUTH_ENABLED=true to require login for all /api routes (login/register
# stay public; register self-gates to admins once a user exists). When enabled,
# JWT_SECRET MUST be set to a strong random value or the server refuses to start.
# Tokens are 7-day JWTs. The users table is created via prisma/manual-sql/005_users.sql
# (NOT prisma migrate). The first registered user becomes the admin.
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_ENABLED=false
JWT_SECRET=your-secret-key-change-in-production

# ============================================
# VENDLIVE INTEGRATION
# ============================================
# Encryption key for VendLive API token storage (32 bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VENDLIVE_ENCRYPTION_KEY=

# ============================================
# AI FEATURES (Optional - for invoice/screenshot analysis)
# ============================================
# ANTHROPIC_API_KEY=sk-ant-...
