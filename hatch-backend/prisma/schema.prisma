// Prisma Schema for Hatch Stock Management System
// Connected to Supabase project: Stock_tracker (tujgcuzqazxixaxrdpws)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============ PRODUCTS ============

model Product {
  sku                 String   @id
  name                String
  description         String?
  category            String?
  unitCost            Float?   @map("unit_cost")
  salePrice           Float?   @map("sale_price")
  unitsPerBox         Int?     @default(1) @map("units_per_box")
  barcode             String?  @unique
  preferredSupplierId String?  @map("preferred_supplier_id")
  // Frive fresh-meal grouping. isFreshMeal flags a weekly-rotating Frive meal;
  // mealType holds the configurable bucket name (see MealType); mealTypeConfirmed
  // gates name-based auto-guesses until a human confirms them.
  isFreshMeal         Boolean  @default(false) @map("is_fresh_meal")
  mealType            String?  @map("meal_type")
  mealTypeConfirmed   Boolean  @default(false) @map("meal_type_confirmed")
  // Generic parent grouping for stable flavour families (e.g. "Barebells").
  // Unlike fresh meals, flavours are ordered as real per-SKU PO lines — the
  // parent is a pure grouping row. A product is never in both systems
  // (enforced in the product-parents route). Partial index on parent_id lives
  // in manual SQL. See prisma/manual-sql/026_product_parents.sql.
  parentId            String?  @map("parent_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  parent            ProductParent?   @relation(fields: [parentId], references: [id], onDelete: SetNull)
  preferredSupplier Supplier?        @relation(fields: [preferredSupplierId], references: [id])
  warehouseStock    WarehouseStock[]
  locationStock     LocationStock[]
  stockBatches      StockBatch[]
  orderItems        OrderItem[]
  sales             Sale[]
  locationConfigs   LocationConfig[]

  @@map("products")
}

// ============ WAREHOUSES ============

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  stock         WarehouseStock[]
  stockBatches  StockBatch[]
  removals      StockRemoval[]
  transfersFrom StockTransfer[]  @relation("TransfersFrom")
  transfersTo   StockTransfer[]  @relation("TransfersTo")

  @@map("warehouses")
}

model WarehouseStock {
  warehouseId String   @map("warehouse_id")
  sku         String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@id([warehouseId, sku])
  @@map("warehouse_stock")
}

// ============ LOCATIONS ============

model Location {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("vending") // vending, retail, storage
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  // Ordering parameters (nullable overrides; null -> code defaults in
  // src/config/ordering.js). See manual-sql/006_ordering_config.sql.
  leadTimeDays Int? @map("lead_time_days")
  coverDays    Int? @map("cover_days")

  // Retired locations: kept for historical reporting but hidden from the
  // active locations list. Sales are tagged by name (not FK) so their history
  // survives regardless. See manual-sql/010_archive_locations.sql.
  archivedAt DateTime? @map("archived_at")

  // Relations
  stock              LocationStock[]
  configs            LocationConfig[]
  mealConfigs        LocationMealConfig[]
  parentConfigs      LocationParentConfig[]
  restocks           RestockRecord[]
  stockChecks        StockCheck[]
  assignedItems      LocationAssignment[]
  machineMappings    VendliveMachineMapping[]
  vendliveStockSyncs VendliveStockSync[]
  machineLayouts     MachineLayout[]

  @@map("locations")
}

// Visual planogram: manually configured fridge layout for a location.
// shelves Json: [{ shelf: 1, slots: 6 }, ...] — shelf 1 = top of the fridge,
// slots = equal-width facings (1..26, lettered A..Z left to right).
// One layout per location in V1 (every site has a single fridge; a
// two-fridge site would need a machineId on this model — future).
// See manual-sql/019_visual_planogram.sql.
model MachineLayout {
  id         String   @id @default(uuid())
  locationId String   @map("location_id")
  // 'current' = the live layout; 'next' = the draft for the coming restock
  // Monday. Ordering/picking prefer 'next'; the public restock sheet pins
  // 'current'. See manual-sql/024_layout_revisions.sql.
  revision   String   @default("current")
  shelves    Json
  // Public restock-sheet share link credential (same pattern as
  // BuyingList.shareToken): the unguessable uuid IS the credential for the
  // read-only 3PL sheet at /share/restock-sheet/:token.
  shareToken String   @unique @default(uuid()) @map("share_token")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  location    Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  assignments SlotAssignment[]

  @@unique([locationId, revision])
  @@map("machine_layouts")
}

// Temporal slot assignments — the source of truth for what is IN the fridge
// this week (the location's mirrored product list is a superset; assigning a
// slot is the act of declaring a product in-machine). Append-only: the
// current planogram is the rows WHERE valid_to IS NULL, enforced by a partial
// unique index on (layout_id, shelf, position) — created in the manual SQL,
// not expressible in Prisma. Saves close changed rows and open new ones, so
// sales can later join (location_id, sku, timestamp) -> slot position for the
// shelf heatmap. sku has NO FK (matches LocationAssignment) so history
// survives product churn. A slot targets either a concrete SKU or a
// fresh-meal bucket (targetType 'mealType') — Frive flavours rotate weekly
// inside a stable group slot.
model SlotAssignment {
  id         String    @id @default(uuid())
  layoutId   String    @map("layout_id")
  locationId String    @map("location_id") // denormalised for heatmap joins
  shelf      Int // 1 = top
  position   Int // 0-based within shelf; A = 0
  slotCode   String    @map("slot_code") // "1A" — denormalised for restock sheets
  targetType String    @map("target_type") // 'sku' | 'mealType' | 'parent'
  sku        String?
  mealType   String?   @map("meal_type")
  // Product-family slot ("any Barebells flavour in this facing"). References
  // product_parents.id but deliberately NO FK, matching sku/mealType above —
  // append-only history must survive churn. See manual-sql/027_planogram_parent_slots.sql.
  parentId   String?   @map("parent_id")
  // Per-slot fill capacity override (units in this facing). The shelf default
  // lives in MachineLayout.shelves entries as unitsPerSlot; effective capacity
  // = capacity ?? shelf.unitsPerSlot, summed per target across its slots.
  // A capacity change updates the open row IN PLACE (not part of slot history).
  // See manual-sql/022_slot_capacity.sql.
  capacity   Int?
  validFrom  DateTime  @default(now()) @map("valid_from")
  validTo    DateTime? @map("valid_to")

  layout MachineLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([locationId, validTo])
  @@index([layoutId, validTo])
  @@map("slot_assignments")
}

// Admin-managed list of fresh-meal buckets (e.g. "Meat", "Veg/Vegan").
// Configurable rather than an enum. Referenced by Product.mealType and
// LocationMealConfig.mealType by NAME (denormalised — renames are coordinated
// transactionally in the meal-types route).
model MealType {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("meal_types")
}

// Parent product for a stable flavour family ("Barebells", "Estate Dairy").
// Pure grouping row — never stocked, sold, or ordered; flavours are ordinary
// products linked via Product.parentId (FK by id, so renames need no cascade —
// deliberately unlike the fresh-meal name-string link).
// See prisma/manual-sql/026_product_parents.sql.
model ProductParent {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products        Product[]
  locationConfigs LocationParentConfig[]

  @@map("product_parents")
}

// Per-(location, parent) capacity for flavour-family group rows — mirrors
// LocationMealConfig. Current stock for a family is the SUM of member SKUs'
// location_stock; only min/max capacity lives here. Consumed by ordering and
// picking in later phases.
model LocationParentConfig {
  locationId String @map("location_id")
  parentId   String @map("parent_id")
  minStock   Int?   @map("min_stock")
  maxStock   Int?   @map("max_stock")

  location Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  parent   ProductParent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([locationId, parentId])
  @@map("location_parent_config")
}

// Per-(location, meal type) capacity for collapsed fresh-meal group rows.
// Current stock for a group is the SUM of member SKUs' location_stock — only the
// min/max capacity lives here.
model LocationMealConfig {
  locationId String @map("location_id")
  mealType   String @map("meal_type")
  minStock   Int?   @map("min_stock")
  maxStock   Int?   @map("max_stock")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, mealType])
  @@map("location_meal_config")
}

model LocationStock {
  locationId String   @map("location_id")
  sku        String
  quantity   Int      @default(0)
  // Earliest expiry date among this SKU's channels in the machine, captured
  // from VendLive channel data on each stock sync (null when VendLive doesn't
  // report one). Refreshed wholesale per sync — sale decrements don't touch
  // it. Drives "expires in machine before next restock" alerts. See
  // manual-sql/014_expiry_intel.sql.
  earliestExpiry DateTime? @map("earliest_expiry")
  updatedAt  DateTime @updatedAt @map("updated_at")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@id([locationId, sku])
  @@index([earliestExpiry])
  @@map("location_stock")
}

model LocationConfig {
  locationId String @map("location_id")
  sku        String
  minStock   Int?   @map("min_stock")
  maxStock   Int?   @map("max_stock")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@id([locationId, sku])
  @@map("location_config")
}

model LocationAssignment {
  locationId String @map("location_id")
  sku        String

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, sku])
  @@map("location_assignments")
}

// ============ STOCK BATCHES (Expiry Tracking) ============

model StockBatch {
  id           String    @id @default(uuid())
  warehouseId  String    @map("warehouse_id")
  sku          String
  quantity     Int
  remainingQty Int       @map("remaining_qty")
  expiryDate   DateTime? @map("expiry_date")
  hasDamage    Boolean   @default(false) @map("has_damage")
  damageNotes  String?   @map("damage_notes")
  receivedAt   DateTime  @default(now()) @map("received_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@index([warehouseId, sku])
  @@index([expiryDate])
  @@map("stock_batches")
}

// ============ SUPPLIERS ============

model Supplier {
  id        String   @id @default(uuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  // Ordering config (see manual-sql/015_supplier_config.sql):
  // orderDays — weekdays this supplier accepts orders, lowercase short names
  // e.g. ["wed","thu"]; null = any day. minOrderValue — order minimum in £;
  // buying lists warn when a supplier group falls short. leadTimeDays — days
  // from placing the order to delivery; drives PO expectedDate.
  orderDays     Json?  @map("order_days")
  leadTimeDays  Int?   @map("lead_time_days")
  minOrderValue Float? @map("min_order_value")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  orders   Order[]
  products Product[]

  @@map("suppliers")
}

// ============ ORDERS ============

model Order {
  id             String    @id @default(uuid())
  supplierId     String?   @map("supplier_id")
  status         String    @default("pending") // pending, received, cancelled
  deliveryMethod String?   @map("delivery_method")
  deliveryTo     String?   @map("delivery_to")
  // Delivery destination: a warehouse (receiving pre-selects it) OR a free-text
  // custom address. Previously collected by the PO form but silently dropped
  // here — manual-sql/025 adds the columns.
  warehouseId    String?   @map("warehouse_id")
  customAddress  String?   @map("custom_address")
  deliveryFee    Float?    @map("delivery_fee")
  notes          String?
  invoiceRef     String?   @map("invoice_ref")
  totalAmount    Float?    @map("total_amount")
  // Expected delivery date (weekend delivery for the Monday restock cycle).
  expectedDate   DateTime? @map("expected_date")
  // Set when this PO was created from a BuyingList (one PO per supplier).
  buyingListId   String?   @map("buying_list_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  receivedAt     DateTime? @map("received_at")

  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  items    OrderItem[]
  receipts OrderReceipt[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  sku       String
  quantity  Int
  // Units booked in so far across all receipts — supports partial receiving.
  // The order flips to `received` only when every line is fully received or
  // the operator explicitly closes it short.
  receivedQty Int   @default(0) @map("received_qty")
  unitPrice Float? @map("unit_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [sku], references: [sku])

  @@index([orderId])
  @@map("order_items")
}

// One row per receiving event against a PO. A short weekend delivery stays
// `pending` with receivedQty tracking the shortfall until a later receipt (or
// an explicit close-short) completes it. items allows MULTIPLE lines per SKU
// so two date-lots of the same product can be recorded truthfully:
// [{ sku, quantity, expiryDate?, hasDamage?, damageNotes? }]
model OrderReceipt {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  warehouseId String   @map("warehouse_id")
  items       Json
  closedShort Boolean  @default(false) @map("closed_short")
  receivedBy  String?  @map("received_by")
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_receipts")
}

// ============ BUYING LISTS ============

// The weekly consolidated buying list: one shareable, supplier-grouped list
// generated from order suggestions (netted against warehouse stock + pending
// POs). Lives in the platform; share via public token link, PDF, or
// copy-as-text. Creating orders from it produces one PO per supplier.
// items: [{ sku, name, mealType?, isFreshMeal?, supplierId, supplierName,
//           quantity, boxes, unitsPerBox, unitCost,
//           machineStock, projectedStock, warehouseStock, pendingPOQty,
//           grossNeed, netNeed, priority, perLocation: [...] }]
model BuyingList {
  id         String    @id @default(uuid())
  name       String
  status     String    @default("draft") // draft, ordered, archived
  targetDate DateTime? @map("target_date") // the restock Monday this buy covers
  shareToken String    @unique @default(uuid()) @map("share_token")
  items      Json
  notes      String?
  orderIds   Json?     @map("order_ids") // POs created from this list
  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("buying_lists")
}

// ============ PICK LISTS ============

// "What to pack into bags tonight for tomorrow's restock run." Generated per
// route + target date: per-location fill-to-max quantities aggregated per SKU,
// with warehouse batches allocated FEFO so the packer knows exactly which
// date-lot to pull. Completing a pick list creates the StockRemoval (linked
// via removalId) so warehouse decrements reconcile with the run.
// items: [{ sku, name, totalQty, packedQty?, packed?,
//           perLocation: [{ locationId, locationName, qty }],
//           batches: [{ batchId, qty, expiryDate, receivedAt }] }]
model PickList {
  id          String    @id @default(uuid())
  routeId     String?   @map("route_id")
  routeName   String?   @map("route_name")
  warehouseId String    @map("warehouse_id")
  targetDate  DateTime  @map("target_date")
  status      String    @default("draft") // draft, packed, cancelled
  items       Json
  shortfalls  Json? // [{ sku, name, requested, available }]
  removalId   String?   @map("removal_id")
  // Leftovers returned to the warehouse after the run (van reconciliation):
  // [{ sku, quantity, returnedAt }]. Booked back as batches with the earliest
  // expiry of that SKU's original allocation (conservative for FEFO).
  returnedItems Json?   @map("returned_items")
  // Configured targets skipped at generation because they have no slot on the
  // location's visual diagram: [{ locationId, locationName, skus: [{sku,name}],
  // mealTypes: [str] }]. See manual-sql/023_pick_list_planogram.sql.
  notOnPlanogram Json?  @map("not_on_planogram")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([targetDate])
  @@index([createdAt])
  @@map("pick_lists")
}

// ============ STOCK MOVEMENTS ============

model StockRemoval {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  routeId     String?  @map("route_id")
  routeName   String?  @map("route_name")
  takenBy     String?  @map("taken_by")
  notes       String?
  items       Json // [{ sku, quantity }]
  createdAt   DateTime @default(now()) @map("created_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId, createdAt])
  @@map("stock_removals")
}

model StockTransfer {
  id              String   @id @default(uuid())
  fromWarehouseId String   @map("from_warehouse_id")
  toWarehouseId   String   @map("to_warehouse_id")
  performedBy     String?  @map("performed_by")
  notes           String?
  items           Json // [{ sku, quantity }]
  createdAt       DateTime @default(now()) @map("created_at")

  fromWarehouse Warehouse @relation("TransfersFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("TransfersTo", fields: [toWarehouseId], references: [id])

  @@index([fromWarehouseId, createdAt])
  @@index([toWarehouseId, createdAt])
  @@map("stock_transfers")
}

model RestockRecord {
  id          String   @id @default(uuid())
  locationId  String   @map("location_id")
  // Set when this restock loaded stock packed on a pick list — links the
  // route-run loop (pick → van → machine) so van reconciliation can compare
  // packed vs loaded per SKU. See manual-sql/013_route_run.sql.
  pickListId  String?  @map("pick_list_id")
  performedBy String?  @map("performed_by")
  items       Json // [{ sku, quantity }]
  photoUrl    String?  @map("photo_url")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId, createdAt])
  @@index([pickListId])
  @@map("restock_records")
}

model StockCheck {
  id                  String   @id @default(uuid())
  locationId          String   @map("location_id")
  performedBy         String?  @map("performed_by")
  items               Json // [{ sku, expected, counted, variance }]
  source              String? // 'manual' | 'vendlive'
  vendliveStockSyncId String?  @map("vendlive_stock_sync_id")
  createdAt           DateTime @default(now()) @map("created_at")

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId, createdAt])
  @@map("stock_checks")
}

// ============ RESTOCK ROUTES ============

model RestockRoute {
  id          String   @id @default(uuid())
  name        String
  locationIds Json     @map("location_ids") // Array of location IDs in order
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("restock_routes")
}

// ============ SALES ============

model Sale {
  id            String   @id // Transaction ID from source system
  sku           String
  productName   String?  @map("product_name")
  quantity      Int      @default(1)
  charged       Float
  costPrice     Float?   @map("cost_price")
  paymentMethod String?  @map("payment_method")
  locationName  String?  @map("location_name")
  machineName   String?  @map("machine_name")
  timestamp     DateTime
  importedAt    DateTime @default(now()) @map("imported_at")

  // VendLive integration fields
  vendliveOrderSaleId   Int?    @map("vendlive_order_sale_id")
  vendliveProductSaleId Int?    @map("vendlive_product_sale_id")
  vendliveMachineId     Int?    @map("vendlive_machine_id")
  vendStatus            String? @map("vend_status")
  discountValue         Float?  @map("discount_value")
  vatRate               Float?  @map("vat_rate")
  vatAmount             Float?  @map("vat_amount")
  promotionId           Int?    @map("promotion_id")
  voucherCode           String? @map("voucher_code")
  isRefunded            Boolean @default(false) @map("is_refunded")
  syncSource            String? @map("sync_source") // 'webhook' | 'poll' | 'csv_import'

  product Product? @relation(fields: [sku], references: [sku])

  @@unique([vendliveOrderSaleId, vendliveProductSaleId])
  @@index([timestamp])
  @@index([sku])
  @@map("sales")
}

model SalesImport {
  id           String   @id @default(uuid())
  filename     String
  recordsAdded Int      @map("records_added")
  recordsTotal Int      @map("records_total")
  importedAt   DateTime @default(now()) @map("imported_at")

  @@map("sales_imports")
}

// Generated client-facing PDF reports (Feature 2). The PDF bytes are stored
// inline (pdf_data) so there is no external object store to manage. Regenerating
// for the same site + period + scope creates a NEW row with an incremented
// version rather than overwriting — reports are an audit trail. Client-safe by
// construction: only usage/units/share data is ever rendered into the PDF (see
// services/report-whitelist.js); no revenue, cost, margin or waste.
model ClientReport {
  id            String   @id @default(uuid())
  clientName    String   @map("client_name")
  siteName      String   @map("site_name")
  locationNames Json     @map("location_names") // resolved sales location names in scope
  routeId       String?  @map("route_id")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  version       Int      @default(1)
  fileName      String   @map("file_name")
  pdfData       Bytes    @map("pdf_data")
  pdfSize       Int      @map("pdf_size")
  generatedBy   String?  @map("generated_by")
  generatedAt   DateTime @default(now()) @map("generated_at")

  @@index([siteName, periodStart, periodEnd])
  @@map("client_reports")
}

// ============ VENDLIVE INTEGRATION ============

model VendliveConfig {
  id                   String    @id @default("default")
  apiToken             String?   @map("api_token")
  accountId            String?   @map("account_id")
  baseUrl              String    @default("https://vendlive.com/api/2.0") @map("base_url")
  webhookSecret        String?   @map("webhook_secret")
  salesSyncEnabled     Boolean   @default(false) @map("sales_sync_enabled")
  pollIntervalMin      Int       @default(15) @map("poll_interval_min")
  autoCreateProducts   Boolean   @default(true) @map("auto_create_products")
  lastPollSaleId       Int?      @map("last_poll_sale_id")
  lastPollAt           DateTime? @map("last_poll_at")
  // Stock sync fields
  stockSyncEnabled     Boolean   @default(false) @map("stock_sync_enabled")
  stockPollIntervalMin Int       @default(10) @map("stock_poll_interval_min")
  restockMovementTypes String    @default("In") @map("restock_movement_types")
  autoShrinkageCalc    Boolean   @default(true) @map("auto_shrinkage_calc")
  // Product-catalog sync: proactively pulls all VendLive products (see
  // services/vendlive-stock.js syncProductCatalog). Defaults to daily.
  productSyncEnabled     Boolean   @default(false) @map("product_sync_enabled")
  productSyncIntervalMin Int       @default(1440) @map("product_sync_interval_min")
  lastProductSyncAt      DateTime? @map("last_product_sync_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("vendlive_config")
}

// VendLive exposes TWO machine-id namespaces: the /machines/ API id
// (vendliveMachineId, used by stock sync) and the order-sales/webhook feed id
// (salesMachineId, carried on Sale rows). One physical machine = ONE row here
// holding both ids; the friendly machineName is the cross-namespace key used
// to backfill salesMachineId when a sale is first seen. See
// manual-sql/012_vendlive_trust.sql for the dedupe/backfill migration.
model VendliveMachineMapping {
  id                String   @id @default(uuid())
  vendliveMachineId Int      @unique @map("vendlive_machine_id")
  salesMachineId    Int?     @unique @map("sales_machine_id")
  machineName       String   @map("machine_name")
  locationId        String?  @map("location_id")
  autoCreated       Boolean  @default(false) @map("auto_created")
  // Last-seen planogram for THIS machine: [{ sku, idealCapacity }]. Written on
  // every successful stock sync; a location's assignments are recomputed as
  // the UNION across all its machines' stored planograms, so syncing one
  // machine never wipes a sibling's products. Capacity is stored so
  // cross-machine maxStock sums never need sibling API calls. See
  // manual-sql/018_planogram_mirror.sql and services/planogram-mirror.js.
  planogramSkus     Json?     @map("planogram_skus")
  planogramSyncedAt DateTime? @map("planogram_synced_at")
  createdAt         DateTime @default(now()) @map("created_at")

  location Location? @relation(fields: [locationId], references: [id])

  @@map("vendlive_machine_mappings")
}

// Sales the ingest could not book because the SKU was unknown (auto-create
// off). Instead of skipping-and-advancing (permanent data loss), the raw
// normalized sale is parked here and replayed once the product exists.
// Replay inserts the Sale row only — it does NOT retro-decrement machine
// stock (a later full sync already reflects reality).
model VendliveQuarantinedSale {
  id                    String    @id // vl-<orderSaleId>-<productSaleId>
  vendliveOrderSaleId   Int?      @map("vendlive_order_sale_id")
  vendliveProductSaleId Int?      @map("vendlive_product_sale_id")
  payload               Json // normalized sale row, ready to insert
  reason                String // 'unknown_sku' | ...
  sku                   String?
  productName           String?   @map("product_name")
  machineName           String?   @map("machine_name")
  timestamp             DateTime?
  createdAt             DateTime  @default(now()) @map("created_at")
  resolvedAt            DateTime? @map("resolved_at")

  @@index([resolvedAt])
  @@map("vendlive_quarantined_sales")
}

model VendliveSyncLog {
  id           String   @id @default(uuid())
  syncType     String   @map("sync_type") // 'webhook' | 'poll' | 'manual'
  status       String // 'success' | 'error' | 'partial'
  salesCreated Int      @default(0) @map("sales_created")
  salesSkipped Int      @default(0) @map("sales_skipped")
  salesErrored Int      @default(0) @map("sales_errored")
  errorMessage String?  @map("error_message")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("vendlive_sync_logs")
}

// ============ VENDLIVE STOCK SYNC ============

model VendliveStockSync {
  id                String   @id @default(uuid())
  vendliveMachineId Int      @map("vendlive_machine_id")
  locationId        String?  @map("location_id")
  syncType          String   @map("sync_type") // 'restock_detected' | 'manual_pull' | 'scheduled'
  status            String // 'success' | 'error'
  productsUpdated   Int      @default(0) @map("products_updated")
  totalVariance     Int      @default(0) @map("total_variance")
  varianceCost      Float    @default(0) @map("variance_cost")
  metadata          Json?
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")

  location Location? @relation(fields: [locationId], references: [id])

  @@index([vendliveMachineId, createdAt])
  @@map("vendlive_stock_syncs")
}

model VendliveMovementTracker {
  vendliveMachineId Int      @id @map("vendlive_machine_id")
  lastMovementId    Int      @map("last_movement_id")
  lastMovementAt    DateTime @map("last_movement_at")
  lastSyncAt        DateTime @map("last_sync_at")

  @@map("vendlive_movement_trackers")
}

// ============ ATTENTION DISMISSALS ============

// Admin dismissals of Dashboard "Needs attention" items. One active dismissal
// per itemId (upserted). The signature is the item's rendered title — counts
// live in the title, so when the underlying signal changes the signature no
// longer matches and the item reappears. The frontend also expires dismissals
// after 7 days so nothing stays buried. See manual-sql/017_attention_dismissals.sql.
model AttentionDismissal {
  itemId      String   @id @map("item_id")
  signature   String
  dismissedBy String?  @map("dismissed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("attention_dismissals")
}

// Restock planner calendar (Restock > Planner). The frontend renders the
// weekly defaults itself (Monday = restock, Friday = de-stock); rows here
// only store overrides and ad-hoc entries keyed by (date, kind):
// assignees/notes decorate a default, status 'cancelled' hides it, a row on
// any other day is an ad-hoc run. Deleting a row reverts the day to its
// default. See manual-sql/019_restock_planner.sql.
model RestockPlanEntry {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  kind      String // 'restock' | 'destock'
  status    String   @default("planned") // 'planned' | 'cancelled'
  assignees String[] @default([])
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date, kind])
  @@map("restock_plan_entries")
}

// ============ USERS (Optional Auth) ============

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user") // admin, user
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
